FROM rust:1.86-bookworm AS builder
RUN apt-get update && apt-get install -y libpq-dev pkg-config && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY Cargo.toml Cargo.lock ./
COPY crates/ crates/
COPY migrations/ migrations/
RUN cargo build --release --bin divine-atbridge

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y libpq5 ca-certificates && rm -rf /var/lib/apt/lists/*
RUN useradd -r -u 1000 -m appuser
USER appuser
COPY --from=builder /app/target/release/divine-atbridge /usr/local/bin/divine-atbridge
EXPOSE 8080
CMD ["divine-atbridge"]
