. {
  errors
  log

  template IN A divine.test {
    match ^([a-z0-9-]+)\.divine\.test\.$
    answer "{{ .Name }} 60 IN A 100.64.0.10"
    fallthrough
  }

  template IN TXT divine.test {
    match ^_atproto\.([a-z0-9-]+)\.divine\.test\.$
    answer "{{ .Name }} 60 IN TXT \"did=did:plc:REPLACE_WITH_HANDLE_ADMIN\""
    fallthrough
  }

  hosts {
    100.64.0.20 handles.example-tailnet.ts.net
    fallthrough
  }

  forward . 1.1.1.1 8.8.8.8
}
