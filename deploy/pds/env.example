# =============================================================================
# rsky-pds Configuration
# Copy this file to .env and fill in the values.
# =============================================================================

# -- PDS Identity --------------------------------------------------------
# The public hostname of this PDS instance.
PDS_HOSTNAME=pds.divine.video

# The DID identifying this PDS service (typically did:web:<hostname>).
PDS_SERVICE_DID=did:web:pds.divine.video

# Handle domain suffix(es) this PDS is authoritative for.
PDS_SERVICE_HANDLE_DOMAINS=.divine.video

# -- Database ------------------------------------------------------------
# These are used by both PostgreSQL container and the PDS DATABASE_URL.
POSTGRES_USER=pds
POSTGRES_PASSWORD=pds_dev_password
POSTGRES_DB=pds

# -- Blob Storage (S3 / MinIO) ------------------------------------------
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1
PDS_BLOBSTORE_S3_BUCKET=pds-blobs
AWS_ENDPOINT_BUCKET=pds-blobs
# AWS_ENDPOINT is set automatically to http://minio:9000 inside docker-compose.

# -- PLC Directory -------------------------------------------------------
PDS_DID_PLC_URL=https://plc.directory

# -- App View (Bluesky relay) -------------------------------------------
PDS_BSKY_APP_VIEW_URL=https://api.bsky.app
PDS_BSKY_APP_VIEW_DID=did:web:api.bsky.app

# -- Admin ---------------------------------------------------------------
PDS_ADMIN_PASSWORD=change-me-in-production

# -- Logging (optional) --------------------------------------------------
# RUST_LOG=info
